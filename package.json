{
  "name": "anistream",
  "version": "1.0.0",
  "description": "Local anime streaming desktop app",
  "main": "src/main.js",
  "bin": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "dev": "nodemon src/main.js",
    "build": "node scripts/build.js",
    "package": "pkg . --out-path dist/"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "assets": [
      "src/frontend/**/*",
      "assets/**/*",
      "node_modules/systray2/traybin/tray_windows_release.exe"
    ],
    "icon": "assets/fox_mask.ico",
    "outputPath": "dist"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "esbuild": "^0.28.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "node-schedule": "^2.1.1",
    "open": "^8.4.2",
    "puppeteer-core": "^24.43.1",
    "systray2": "^2.1.4",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "pkg": "^5.8.1"
  },
  "author": "pochira",
  "license": "ISC"
}
